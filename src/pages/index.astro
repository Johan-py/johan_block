---
const researchAreas = [
  {
    name: 'Linux',
    icon: '󰣇',
    desc: 'Kernel, Systemd, Hardening y administración.'
  },
  {
    name: 'Security',
    icon: '󰒃',
    desc: 'OSINT, Recon, Pentesting y Blue Team.'
  },
  {
    name: 'Infrastructure',
    icon: '󰒋',
    desc: 'Docker, redes, servicios y observabilidad.'
  },
  {
    name: 'Programming',
    icon: '󰌠',
    desc: 'Python, Rust y automatización.'
  },
  {
    name: 'Hardware',
    icon: '󰍹',
    desc: 'ESP32, SDR y proyectos DIY.'
  },
  {
    name: 'Homelab',
    icon: '󰌢',
    desc: 'Virtualización y laboratorios.'
  }
];

const techStack = [
  { label: 'Arch Linux', cat: 'os' }, { label: 'Debian', cat: 'os' },
  { label: 'Python', cat: 'lang' }, { label: 'Rust', cat: 'lang' }, { label: 'Bash', cat: 'lang' },
  { label: 'Docker', cat: 'infra' }, { label: 'K8s', cat: 'infra' },
  { label: 'ESP32', cat: 'hw' }, { label: 'SDR', cat: 'hw' },
  { label: 'Wireshark', cat: 'sec' }, { label: 'Burp', cat: 'sec' }, { label: 'Metasploit', cat: 'sec' },
  { label: 'Nginx', cat: 'infra' }, { label: 'Git', cat: 'tool' },
  { label: 'Systemd', cat: 'os' }, { label: 'AWS', cat: 'infra' },
];

const stats = [
  {
    value: 'Arch',
    label: 'Main OS'
  },
  {
    value: 'Python',
    label: 'Primary Language'
  },
  {
    value: 'CTF',
    label: 'Learning Method'
  },
  {
    value: '24/7',
    label: 'Curiosity'
  }
];

const focus = [
  'Linux Internals',
  'Networking',
  'Rust',
  'ESP32 Research',
  'Containerization',
  'Threat Hunting'
];

const philosophy = [
  'If I cannot explain it, I do not understand it.',
  'Documentation is part of the project.',
  'Automation prevents repeated mistakes.',
  'Every system leaves traces.',
  'Break. Analyze. Rebuild.'
];
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>johan@dantalion — Bitácora de un Sysadmin</title>
  <meta name="description" content="Blog técnico sobre Linux, ciberseguridad, DevOps e infraestructura. Documentación de proyectos reales, análisis de herramientas y experiencias de aprendizaje." />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300..700;1,300..700&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="crt-overlay"></div>

  <!-- STATUS BAR -->
  <header class="status-bar">
    <div class="status-left">
      <span class="status-prompt">></span>
      <span class="status-path">Johan-py</span>
    </div>
    <div class="status-right">
      <span class="status-time" id="clock">--:--:--</span>
      <span class="status-uptime">UP 0:01</span>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">

    <div class="terminal-window">

      <div class="terminal-header">
        <span></span>
        <span></span>
        <span></span>
      </div>

      <div class="terminal-body">

        <p class="command">
          <span class="prompt">
            johan@dantalion:~$
          </span>

          whoami
        </p>

        <h1>Johan-py</h1>

        <p class="hero-role">
          Linux • Security • Infrastructure • Hardware
        </p>

        <p class="hero-mission">
          Building, breaking and understanding systems.
        </p>

      </div>

    </div>

  </section>
  <!-- ABOUT -->
  <section class="section" id="about">
    <div class="section-header">
      <span class="log-tag info">INFO</span>
      <span class="section-title">:: whoami</span>
    </div>
    <div class="about-card">
      <p>
        Soy <span class="highlight">Johan</span>, desarrollador junior, entusiasta de 
        <span class="highlight">Linux</span>, la <span class="highlight">ciberseguridad</span> 
        y la <span class="highlight">infraestructura</span>.
      </p>
      <p>
        Este blog documenta mis proyectos, investigaciones y experimentos en sistemas, 
        redes, automatización, hardware y seguridad ofensiva y defensiva.
      </p>
      <p>
        Aquí comparto laboratorios prácticos, análisis técnicos, herramientas open source, 
        experiencias con Arch Linux, DevOps, CTFs y el proceso continuo de aprender cómo 
        funcionan realmente los sistemas modernos.
      </p>
      <div class="about-meta">
        <span><span class="dim">status:</span> learning</span>
        <span><span class="dim">level:</span> junior++</span>
        <span><span class="dim">focus:</span> infra/sec</span>
      </div>
    </div>
  </section>
  <!-- FOCUS -->
   <section class="section">

    <div class="section-header">
      <span class="log-tag info">INFO</span>
      <span class="section-title">
        :: cat /proc/current_focus
      </span>
    </div>

    <div class="focus-grid">

      {focus.map(item => (
        <div class="focus-item">
          <span>></span>
          {item}
        </div>
      ))}

    </div>

  </section>
  <!-- STATS ROW -->
  <section class="stats-row">
    {stats.map(s => (
      <div class="stat-item">
        <span class="stat-value">{s.value}</span>
        <span class="stat-label">{s.label}</span>
      </div>
    ))}
  </section>

  <!-- CATEGORIES -->
  <section class="section">

    <div class="section-header">
      <span class="log-tag info">INFO</span>
      <span class="section-title">
        :: ls /research
      </span>
    </div>

    <div class="research-grid">

      {researchAreas.map(area => (

        <div class="research-card">

          <div class="research-header">

            <span class="research-icon">
              {area.icon}
            </span>

            <span class="research-name">
              {area.name}
            </span>

          </div>

          <p>
            {area.desc}
          </p>

        </div>

      ))}

    </div>

  </section>

  <!-- TECH STACK -->
  <section class="section" id="stack">
    <div class="section-header">
      <span class="log-tag info">INFO</span>
      <span class="section-title">:: env | grep -i tech</span>
    </div>
    <div class="stack-grid">
      {techStack.map(t => (
        <span class="tech-tag" data-cat={t.cat}>{t.label}</span>
      ))}
    </div>
  </section>

  <!-- PHILOSOPHY -->
  <div class="philosophy-grid">

    {philosophy.map((item,index)=>(

      <div class="phil-item">

        <span class="phil-icon">
          {String(index+1).padStart(2,"0")}
        </span>

        <p>{item}</p>

      </div>

    ))}

  </div>
  </section>

  <footer class="footer">

    <div class="footer-line"></div>

    <div class="terminal-exit">

      <p>
        johan@dantalion:~$ exit
      </p>

      <p>
        logout
      </p>

      <p>
        connection closed.
      </p>

    </div>

  </footer>

  <script>
    function updateClock() {
      const now = new Date();
      const time = now.toTimeString().slice(0, 8);
      document.getElementById('clock').textContent = time;
    }
    updateClock();
    setInterval(updateClock, 1000);
  </script>
</body>
</html>

<style is:global>
  :root{
    --bg:#07070d;
    --bg-soft:#0c0c18;
    --bg-elevated:#10101c;

    --border:#1a1a28;
    --border-hover:#2a2a40;

    --text:#c8c4b8;
    --text-soft:#9a9ab0;
    --text-dim:#6a6a80;

    --accent:#b8860b;
    --accent-blue:#6a8fc5;

    --success:#4caf50;
    --warning:#b8860b;
    --danger:#b84a4a;

    --radius:8px;

    --content-width:900px;
  }


  *,
  *::before,
  *::after{
    margin:0;
    padding:0;
    box-sizing:border-box;
  }

  html{
    scroll-behavior:smooth;
  }

  body{
    font-family:'JetBrains Mono', monospace;
    background:var(--bg);
    color:var(--text);
    line-height:1.7;
    overflow-x:hidden;
  }
  .crt-overlay{
    position:fixed;
    inset:0;
    pointer-events:none;
    z-index:999;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(255,255,255,.015) 3px
      );
  }

  .status-bar{
    position:sticky;
    top:0;
    z-index:100;
    display:flex;
    justify-content:space-between;
    align-items:center;

    padding:.8rem 1.2rem;

    background:rgba(10,10,20,.95);

    backdrop-filter:blur(12px);

    border-bottom:1px solid var(--border);
  }

  .status-left,
  .status-right{
    display:flex;
    gap:1rem;
  }

  .status-path{
    color:var(--text-dim);
  }

  .status-time{
    color:var(--accent);
  }

  .hero{
    padding:5rem 1.5rem;
  }

  .hero-container{
    max-width:var(--content-width);
    margin:auto;
  }
  .terminal-window{
    background:var(--bg-soft);

    border:1px solid var(--border);

    border-radius:12px;

    overflow:hidden;
  }
  .terminal-header{
    height:42px;

    display:flex;
    align-items:center;

    gap:.5rem;

    padding:0 1rem;

    border-bottom:1px solid var(--border);
  }

  .terminal-header span{
    width:12px;
    height:12px;
    border-radius:50%;

    background:#3a3a4a;
  }

  .terminal-body{
    padding:2rem;
  }

  .prompt{
    color:var(--accent);
  }

  .command{
    color:var(--accent-blue);
  }

  .hero h1{
    margin-top:1rem;

    font-size:clamp(2rem,7vw,4.5rem);

    line-height:1;

    letter-spacing:-2px;
  }
  .hero-role{
    margin-top:1rem;

    color:var(--text-soft);
  }
  .hero-mission{
    margin-top:.5rem;

    color:var(--text-dim);
  }
  .section{
    max-width:var(--content-width);

    margin:auto;

    padding:3rem 1.5rem;

    border-bottom:1px solid rgba(255,255,255,.03);
  }
  .section-header{
    display:flex;
    align-items:center;

    gap:.7rem;

    margin-bottom:2rem;
  }
  .section-title{
    color:var(--accent);

    font-size:.9rem;
  }
  .log-tag{
    padding:.15rem .5rem;

    border-radius:4px;

    font-size:.7rem;

    font-weight:600;
  }

  .log-tag.info{
    background:rgba(106,143,197,.12);
    color:var(--accent-blue);
  }

  .log-tag.warn{
    background:rgba(184,134,11,.12);
    color:var(--accent);
  }

  .about-card{
    background:var(--bg-soft);

    border:1px solid var(--border);

    border-radius:var(--radius);

    padding:1.5rem;
  }

  .highlight{
    color:var(--accent);
  }

  .stats-row{
    max-width:var(--content-width);

    margin:auto;

    padding:2rem 1rem;

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:1rem;
  }
  .stat-item{
    background:var(--bg-soft);

    border:1px solid var(--border);

    padding:1rem;

    text-align:center;
  }
  .stat-value{
    font-size:1.8rem;

    color:var(--accent);

    font-weight:700;
  }
  .focus-grid{
    display:grid;
    gap:1rem;
  }

  .focus-item{
    background:var(--bg-soft);

    border:1px solid var(--border);

    padding:1rem;
  }

  .focus-item span{
    color:var(--accent);

    margin-right:.5rem;
  }

  .research-grid{
    display:grid;

    grid-template-columns:
      repeat(auto-fit,minmax(260px,1fr));

    gap:1rem;
  }

  .research-card{
    background:var(--bg-soft);

    border:1px solid var(--border);

    border-radius:var(--radius);

    padding:1.3rem;

    transition:.2s;
  }
 
  .research-card:hover{
    transform:translateY(-3px);

    border-color:var(--border-hover);
  }

  .research-header{
    display:flex;

    align-items:center;

    gap:.75rem;

    margin-bottom:.75rem;
  }

  .research-icon{
    color:var(--accent-blue);

    font-size:1.2rem;
  }

  .stack-grid{
    display:flex;

    flex-wrap:wrap;

    gap:.75rem;
  }

  .tech-tag{
    background:var(--bg-soft);

    border:1px solid var(--border);

    border-radius:999px;

    padding:.35rem .8rem;

    font-size:.75rem;
  }

  .philosophy-grid{
    display:grid;

    grid-template-columns:
      repeat(auto-fit,minmax(300px,1fr));

    gap:1rem;
  }

  .phil-item{
    display:flex;

    gap:1rem;

    background:var(--bg-soft);

    border:1px solid var(--border);

    padding:1rem;
  }

  .phil-icon{
    color:var(--accent);

    font-weight:700;
  }


  .footer{
    max-width:var(--content-width);

    margin:auto;

    padding:4rem 1.5rem;
  }

  .terminal-exit{
    color:var(--text-dim);

    line-height:2;
  }

  @media (max-width:768px){

    .stats-row{
      grid-template-columns:repeat(2,1fr);
    }

    .hero h1{
      font-size:2.5rem;
    }

  }

  @media (max-width:500px){

    .stats-row{
      grid-template-columns:1fr;
    }

    .research-grid{
      grid-template-columns:1fr;
    }

    .philosophy-grid{
      grid-template-columns:1fr;
    }

  }

</style>
